# ── Database ──────────────────────────────────────────────────────────────────
# UnifyRoute uses SQLite for local data storage
DB_BACKEND=sqlite

# SQLite path
SQLITE_PATH=data/unifyroute.db

# ── Application ────────────────────────────────────────────────────────────────
PORT=6565
HOST=localhost
API_BASE_URL=http://localhost:6565

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Secrets (leave blank — `./unifyroute setup` will auto-generate) ────────────────
MASTER_PASSWORD=
VAULT_MASTER_KEY=
JWT_SECRET=

CONFBACKUP_DIR=./confbackup
METADATA_FILENAME=metadata.json